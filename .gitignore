# ============================================================
# ProxiAlpha — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
venv/*
.venv/
env/

# Dependency lock (generated by install.sh)
requirements.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Data & output
data/
*.xlsx
*.csv
*.xls
output/
exports/

# Paper trading state
paper_trading_state.json

# Logs
*.log
logs/

# Secrets & keys
.env
.env.*
*.pem
*.key
credentials.json

# Node / React Native (mobile app)
node_modules/
.expo/
npm-debug.log*
yarn-error.log*
.yarn/

# Generated assets
*.apk
*.ipa
*.aab

